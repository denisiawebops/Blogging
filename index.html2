    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { primary: '#1e3a8a', secondary: '#3b82f6', accent: '#dbeafe' },
                    animation: { 'fade-in': 'fadeIn 0.5s ease-out forwards', 'slide-up': 'slideUp 0.4s ease-out' },
                    keyframes: {
                        fadeIn: { '0%': { opacity: '0', transform: 'translateY(10px)' }, '100%': { opacity: '1', transform: 'translateY(0)' } },
                        slideUp: { '0%': { transform: 'translateY(20px)', opacity: '0' }, '100%': { transform: 'translateY(0)', opacity: '1' } }
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', system-ui, sans-serif; background: #ffffff; color: #1f2937; }
        .card { background: white; border: 1px solid #e5e7eb; border-radius: 1rem; transition: all 0.3s; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }
        .card:hover { border-color: #3b82f6; box-shadow: 0 20px 25px -5px rgba(59,130,246,0.1); transform: scale(1.02); }
        .btn-primary { background-color: #1e3a8a; color: white; padding: 0.75rem 1.5rem; border-radius: 0.5rem; font-weight: 600; transition: all 0.2s; box-shadow: 0 4px 6px -1px rgba(30,58,138,0.2); }
        .btn-primary:hover { background-color: #2563eb; transform: translateY(-2px); }
        .btn-outline { background: transparent; border: 1px solid #1e3a8a; color: #1e3a8a; padding: 0.75rem 1.5rem; border-radius: 0.5rem; font-weight: 600; transition: all 0.2s; }
        .btn-outline:hover { background-color: #dbeafe; border-color: #2563eb; color: #2563eb; }
        .nav-link { color: #4b5563; font-weight: 500; transition: color 0.2s; }
        .nav-link:hover, .nav-link.active { color: #1e3a8a; }
    </style>
</head>
